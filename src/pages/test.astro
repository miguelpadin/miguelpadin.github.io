---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Experience from '../components/Experience.astro';
import Skills from '../components/Skills.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Marquee from '../components/Marquee.astro';
import { useTranslations } from '../i18n';

const lang = 'en';
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Software engineer with 9+ years of experience. Focused on Vue 3, TypeScript and modern web architecture." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="theme-color" id="theme-color" content="#0C1525" />
    <title>Miguel Padín Domínguez · Software Engineer · Blue Variant</title>

    <!-- Blue theme override — replaces the orange/black palette from global.css -->
    <style is:global>
      :root {
        --color-bg: #0C1525;
        --color-surface: #0F1C2E;
        --color-border: #1A3050;
        --color-accent: #4A9EFF;
      }
      [data-theme="light"] {
        --color-bg: #D6E4F7;
        --color-surface: #C5D8F0;
        --color-border: #A8C4E8;
        --color-accent: #2563EB;
      }
      /* Aurora blobs — recolored to blue */
      .blob-1 {
        background: radial-gradient(circle, rgba(74,158,255,0.12) 0%, transparent 65%) !important;
      }
      .blob-2 {
        background: radial-gradient(circle, rgba(37,99,235,0.09) 0%, transparent 65%) !important;
      }
      .blob-3 {
        background: radial-gradient(circle, rgba(125,191,255,0.07) 0%, transparent 65%) !important;
      }
    </style>

    <script is:inline>
      const t = localStorage.getItem('theme') || 'dark';
      document.documentElement.dataset.theme = t;
      const tc = document.getElementById('theme-color');
      if (tc) tc.setAttribute('content', t === 'light' ? '#D6E4F7' : '#0C1525');
    </script>
  </head>
  <body class="min-h-screen">
    <!-- Dot grid spotlight — blue -->
    <div id="grid-spotlight" style="
      position: fixed; inset: 0; pointer-events: none; z-index: 2;
      background-image: radial-gradient(circle, rgba(74,158,255,0.13) 1px, transparent 1px);
      background-size: 38px 38px;
      -webkit-mask-image: radial-gradient(circle 220px at var(--mx, -500px) var(--my, -500px), black 0%, transparent 100%);
      mask-image: radial-gradient(circle 220px at var(--mx, -500px) var(--my, -500px), black 0%, transparent 100%);
    "></div>

    <!-- Scroll progress bar -->
    <div id="scroll-bar" style="
      position: fixed; top: 0; left: 0; z-index: 100000;
      height: 2px; width: 0%;
      background: var(--color-accent);
      pointer-events: none;
    "></div>

    <Header lang={lang} t={t} />
    <main>
      <Hero t={t} />
      <Marquee />
      <Experience t={t} />
      <Skills t={t} />
      <Contact t={t} />
    </main>
    <Footer t={t} />

    <script>
      const isTouch = window.matchMedia('(pointer: coarse)').matches;

      // ── Split text reveal ─────────────────────────────────────────
      document.querySelectorAll<HTMLElement>('[data-split]').forEach(el => {
        const text = el.textContent || '';
        el.innerHTML = [...text].map((char, i) =>
          `<span class="split-char" style="transition-delay:${(i * 0.045).toFixed(3)}s">${char === ' ' ? '&nbsp;' : char}</span>`
        ).join('');
      });

      const splitObs = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('is-split-visible');
            splitObs.unobserve(e.target);
          }
        });
      }, { threshold: 0.5 });
      document.querySelectorAll('[data-split]').forEach(el => splitObs.observe(el));

      // ── Dot grid spotlight ────────────────────────────────────────
      const grid = document.getElementById('grid-spotlight')!;
      window.addEventListener('mousemove', (e) => {
        grid.style.setProperty('--mx', e.clientX + 'px');
        grid.style.setProperty('--my', e.clientY + 'px');
      }, { passive: true });

      // ── Scroll reveal ──────────────────────────────────────────────
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));

      // ── Scroll progress bar ────────────────────────────────────────
      const scrollBar = document.getElementById('scroll-bar')!;
      window.addEventListener('scroll', () => {
        const pct = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
        scrollBar.style.width = (pct * 100) + '%';
      }, { passive: true });

      // ── Active nav on scroll ───────────────────────────────────────
      const sectionIds = ['experience', 'skills', 'contact'];
      const navLinks = Object.fromEntries(
        sectionIds.map(id => [id, document.querySelector<HTMLElement>(`a[href="#${id}"]`)])
      );

      const resetNav = () => sectionIds.forEach(id => {
        if (navLinks[id]) navLinks[id]!.style.color = 'var(--color-muted)';
      });

      const sectionObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const link = navLinks[entry.target.id];
          if (!link) return;
          link.style.color = entry.isIntersecting ? 'var(--color-accent)' : 'var(--color-muted)';
        });
      }, { threshold: 0.25 });

      sectionIds.forEach(id => {
        const el = document.getElementById(id);
        if (el) sectionObserver.observe(el);
      });

      // ── Tab title visibility easter egg ───────────────────────────
      const staticTitle = document.title;
      const awayMsg: Record<string, string> = {
        es: '👋 ¡Hasta pronto!',
        gl: '👋 Ata logo!',
        en: '👋 See you soon!',
      };
      document.addEventListener('visibilitychange', () => {
        const lang = document.documentElement.lang || 'en';
        document.title = document.hidden ? (awayMsg[lang] ?? awayMsg.en) : staticTitle;
      });

      // ── Cursor particle trail — blue ──────────────────────────────
      if (!isTouch) {
        const trail = document.createElement('canvas');
        trail.style.cssText = 'position:fixed;inset:0;pointer-events:none;z-index:999990;';
        document.body.appendChild(trail);
        const tc = trail.getContext('2d')!;

        function resizeTrail() {
          trail.width  = window.innerWidth;
          trail.height = window.innerHeight;
        }
        resizeTrail();
        window.addEventListener('resize', resizeTrail, { passive: true });

        type Particle = { x: number; y: number; life: number; size: number };
        const particles: Particle[] = [];

        document.addEventListener('mousemove', (e) => {
          if (Math.random() > 0.4) return;
          particles.push({ x: e.clientX, y: e.clientY, life: 1, size: Math.random() * 2.5 + 1 });
        });

        (function drawTrail() {
          tc.clearRect(0, 0, trail.width, trail.height);
          for (let i = particles.length - 1; i >= 0; i--) {
            const p = particles[i];
            p.life -= 0.045;
            if (p.life <= 0) { particles.splice(i, 1); continue; }
            tc.globalAlpha = p.life * 0.55;
            tc.fillStyle = '#4A9EFF';
            tc.beginPath();
            tc.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
            tc.fill();
          }
          tc.globalAlpha = 1;
          requestAnimationFrame(drawTrail);
        })();
      }

      // ── Update theme-color on theme change ────────────────────────
      const themeColorMeta = document.getElementById('theme-color') as HTMLMetaElement | null;
      new MutationObserver(() => {
        const dark = document.documentElement.dataset.theme !== 'light';
        if (themeColorMeta) themeColorMeta.content = dark ? '#0C1525' : '#D6E4F7';
      }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

      // ── Service worker ────────────────────────────────────────────
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register(`${import.meta.env.BASE_URL}sw.js`);
      }
    </script>
  </body>
</html>
