---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page not found — Miguel Padín Domínguez"
  description="The page you are looking for does not exist."
>
  <div id="root" style="min-height: 80vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem; text-align: center;">
    <h1 style="
      font-family: var(--font-display);
      font-weight: var(--font-display-weight);
      font-size: clamp(4rem, 15vw, 8rem);
      color: var(--color-accent);
      margin: 0 0 0.5rem;
      line-height: 1;
    ">404</h1>

    <p id="msg" style="
      font-family: var(--font-body);
      font-size: 1rem;
      color: var(--color-muted);
      margin: 0 0 2rem;
      line-height: 1.75;
    ">
      The page you are looking for does not exist.
    </p>

    <a id="back" href="/"
      style="
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--font-display);
        font-weight: var(--font-display-weight);
        font-size: 0.625rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--color-accent);
        text-decoration: none;
        transition: opacity 0.2s;
      "
      class="back-link-404"
    >&larr; Back to home</a>
  </div>

  <script>
    (() => {
      const lang = location.pathname.match(/^\/(es|gl)\//)?.[1] || 'en';
      const t = {
        en: { msg: 'The page you are looking for does not exist.', back: '\u2190 Back to home', title: 'Page not found \u2014 Miguel Pad\u00edn Dom\u00ednguez' },
        es: { msg: 'La p\u00e1gina que buscas no existe.', back: '\u2190 Volver al inicio', title: 'P\u00e1gina no encontrada \u2014 Miguel Pad\u00edn Dom\u00ednguez' },
        gl: { msg: 'A p\u00e1xina que buscas non existe.', back: '\u2190 Volver ao inicio', title: 'P\u00e1xina non atopada \u2014 Miguel Pad\u00edn Dom\u00ednguez' },
      }[lang];

      document.getElementById('msg').textContent = t.msg;
      const back = document.getElementById('back');
      back.textContent = t.back;
      back.href = lang === 'en' ? '/' : '/' + lang + '/';
      document.title = t.title;
    })();
  </script>
</Layout>
