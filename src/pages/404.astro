---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page not found — Miguel Padín Domínguez"
  description="The page you are looking for does not exist."
>
  <div style="min-height: 80vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem; text-align: center;">
    <h1 style="
      font-family: var(--font-display);
      font-weight: var(--font-display-weight);
      font-size: clamp(4rem, 15vw, 8rem);
      color: var(--color-accent);
      margin: 0 0 0.5rem;
      line-height: 1;
    ">404</h1>

    <p style="
      font-family: var(--font-body);
      font-size: 1rem;
      color: var(--color-muted);
      margin: 0 0 2rem;
      line-height: 1.75;
    ">
      The page you are looking for does not exist.
    </p>

    <a
      href="/"
      style="
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--font-display);
        font-weight: var(--font-display-weight);
        font-size: 0.625rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--color-accent);
        text-decoration: none;
        transition: opacity 0.2s;
      "
      class="back-link-404"
    >← Back to home</a>
  </div>
</Layout>
