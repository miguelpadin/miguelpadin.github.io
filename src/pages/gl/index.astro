---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Experience from '../../components/Experience.astro';
import Skills from '../../components/Skills.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import Marquee from '../../components/Marquee.astro';
import { useTranslations } from '../../i18n';

const lang = 'gl';
const t = useTranslations(lang);
---

<Layout
  title="Miguel Padín Domínguez · Enxeñeiro de Software · Vue, TypeScript & Python"
  description="Enxeñeiro de software con máis de 9 anos de experiencia. Especializado en Vue 3, TypeScript e arquitectura web moderna."
  lang={lang}
>
  <Header lang={lang} t={t} />
  <main>
    <Hero t={t} />
    <Marquee />
    <Experience t={t} />
    <Skills t={t} />
    <Contact t={t} />
  </main>
  <Footer t={t} lang={lang} />
</Layout>
