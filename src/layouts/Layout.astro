---
import { execSync } from 'node:child_process';
import '../styles/global.css';
import { useTranslations, type Lang, languages } from '../i18n';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const {
  title = 'Miguel Padín Domínguez — Software Engineer',
  lang = 'en',
} = Astro.props;

const description = Astro.props.description ?? useTranslations(lang).hero.description;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteUrl = String(Astro.site).replace(/\/$/, '');
const commitHash = execSync('git rev-parse --short HEAD').toString().trim();
const commitDate = execSync('git log -1 --format=%cd').toString().trim();
const commitMsg = execSync('git log -1 --format=%s').toString().trim();

const jobTitles: Record<string, string> = {
  en: 'Software Engineer',
  es: 'Ingeniero de Software',
  gl: 'Enxeñeiro de Software',
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Miguel Padín Domínguez',
  jobTitle: jobTitles[lang] ?? jobTitles.en,
  url: siteUrl + '/',
  email: 'miguel.padin.dominguez@gmail.com',
  image: siteUrl + '/og-image.svg',
  sameAs: [
    'https://linkedin.com/in/miguelpadin',
    'https://github.com/miguelpadin',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Las Palmas de Gran Canaria',
    addressCountry: 'ES',
  },
  knowsAbout: ['Vue.js', 'Nuxt', 'TypeScript', 'Python', 'Odoo', 'PostgreSQL', 'Node.js', 'DDD', 'Clean Architecture', 'TDD'],
};

// -- Dynamic hreflang --
const rawPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const locales = Object.keys(languages) as Lang[];

function hreflangUrl(targetLang: Lang): string {
  let resultPath: string;
  if (lang === 'en') {
    const base = rawPath === '/' ? '' : rawPath;
    resultPath = targetLang === 'en' ? base + '/' : '/' + targetLang + base + '/';
  } else {
    const prefix = '/' + lang;
    const base = rawPath.startsWith(prefix) ? rawPath.slice(prefix.length) : rawPath;
    resultPath = targetLang === 'en' ? (base || '/') : '/' + targetLang + (base || '') + '/';
  }
  if (resultPath !== '/') resultPath = resultPath.replace(/\/?$/, '/');
  return siteUrl + resultPath;
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <Fragment set:html={`<!-- Developed by Miguel Padín Domínguez — https://miguelpadin.github.io/ -->`} />
    <Fragment set:html={`<!-- Build: ${commitDate} | ${commitMsg} | ${commitHash} -->`} />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Miguel Padín Domínguez" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Miguel Padín Domínguez" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : lang === 'es' ? 'es_ES' : 'gl_ES'} />
    <meta property="og:image" content={`${siteUrl}/og-image.svg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.svg`} />

    <!-- hreflang -->
    {locales.map(l => (
      <link rel="alternate" hreflang={l} href={hreflangUrl(l)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={hreflangUrl('en')} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href={`${import.meta.env.BASE_URL}sitemap.xml`} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" /></noscript>
    <meta name="theme-color" id="theme-color" content="#0C1525" />
    <title>{title}</title>

    <!-- Google tag (gtag.js) — consent denied by default until user accepts -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', { analytics_storage: 'denied' });
    </script>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2R8M9VFJM9"></script>
    <script is:inline>
      gtag('js', new Date());
      gtag('config', 'G-2R8M9VFJM9');
    </script>

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <script is:inline>
      const t = localStorage.getItem('theme') || 'dark';
      document.documentElement.dataset.theme = t;
      const tc = document.getElementById('theme-color');
      if (tc) tc.setAttribute('content', t === 'light' ? '#D6E4F7' : '#0C1525');
    </script>
  </head>
  <body class="min-h-screen">
    <!-- Dot grid spotlight -->
    <div id="grid-spotlight" style="
      position: fixed; inset: 0; pointer-events: none; z-index: 2;
      background-image: radial-gradient(circle, rgba(74,158,255,0.13) 1px, transparent 1px);
      background-size: 38px 38px;
      -webkit-mask-image: radial-gradient(circle 220px at var(--mx, -500px) var(--my, -500px), black 0%, transparent 100%);
      mask-image: radial-gradient(circle 220px at var(--mx, -500px) var(--my, -500px), black 0%, transparent 100%);
    "></div>

    <!-- Scroll progress bar -->
    <div id="scroll-bar" style="
      position: fixed; top: 0; left: 0; z-index: 100000;
      height: 2px; width: 0%;
      background: var(--color-accent);
      pointer-events: none;
    "></div>

    <slot />

    <CookieBanner lang={lang} />

    <script>
      const isTouch = window.matchMedia('(pointer: coarse)').matches;

      // ── Split text reveal ─────────────────────────────────────────
      document.querySelectorAll<HTMLElement>('[data-split]').forEach(el => {
        const text = el.textContent || '';
        el.innerHTML = [...text].map((char, i) =>
          `<span class="split-char" style="transition-delay:${(i * 0.045).toFixed(3)}s">${char === ' ' ? '&nbsp;' : char}</span>`
        ).join('');
      });

      const splitObs = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('is-split-visible');
            splitObs.unobserve(e.target);
          }
        });
      }, { threshold: 0.5 });
      document.querySelectorAll('[data-split]').forEach(el => splitObs.observe(el));

      // ── Dot grid spotlight ────────────────────────────────────────
      const grid = document.getElementById('grid-spotlight')!;
      window.addEventListener('mousemove', (e) => {
        grid.style.setProperty('--mx', e.clientX + 'px');
        grid.style.setProperty('--my', e.clientY + 'px');
      }, { passive: true });

      // ── Scroll reveal ──────────────────────────────────────────────
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));

      // ── Scroll progress bar ────────────────────────────────────────
      const scrollBar = document.getElementById('scroll-bar')!;
      window.addEventListener('scroll', () => {
        const pct = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
        scrollBar.style.width = (pct * 100) + '%';
      }, { passive: true });

      // ── Active nav on scroll ───────────────────────────────────────
      const sectionIds = ['experience', 'skills', 'contact'];
      const navLinks = Object.fromEntries(
        sectionIds.map(id => [id, document.querySelector<HTMLElement>(`a[href="#${id}"]`)])
      );

      const resetNav = () => sectionIds.forEach(id => {
        if (navLinks[id]) navLinks[id]!.style.color = 'var(--color-muted)';
      });

      const sectionObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const link = navLinks[entry.target.id];
          if (!link) return;
          link.style.color = entry.isIntersecting ? 'var(--color-accent)' : 'var(--color-muted)';
        });
      }, { threshold: 0.25 });

      sectionIds.forEach(id => {
        const el = document.getElementById(id);
        if (el) sectionObserver.observe(el);
      });

      // ── Tab title visibility easter egg ───────────────────────────
      const staticTitle = document.title;
      const awayMsg: Record<string, string> = {
        es: '👋 ¡Hasta pronto!',
        gl: '👋 Ata logo!',
        en: '👋 See you soon!',
      };
      document.addEventListener('visibilitychange', () => {
        const lang = document.documentElement.lang || 'en';
        document.title = document.hidden ? (awayMsg[lang] ?? awayMsg.en) : staticTitle;
      });


      // ── Cursor particle trail ─────────────────────────────────────
      if (!isTouch) {
        const trail = document.createElement('canvas');
        trail.style.cssText = 'position:fixed;inset:0;pointer-events:none;z-index:999990;';
        document.body.appendChild(trail);
        const tc = trail.getContext('2d')!;

        function resizeTrail() {
          trail.width  = window.innerWidth;
          trail.height = window.innerHeight;
        }
        resizeTrail();
        window.addEventListener('resize', resizeTrail, { passive: true });

        type Particle = { x: number; y: number; life: number; size: number };
        const particles: Particle[] = [];

        document.addEventListener('mousemove', (e) => {
          if (Math.random() > 0.4) return;
          particles.push({ x: e.clientX, y: e.clientY, life: 1, size: Math.random() * 2.5 + 1 });
        });

        (function drawTrail() {
          tc.clearRect(0, 0, trail.width, trail.height);
          for (let i = particles.length - 1; i >= 0; i--) {
            const p = particles[i];
            p.life -= 0.045;
            if (p.life <= 0) { particles.splice(i, 1); continue; }
            tc.globalAlpha = p.life * 0.55;
            tc.fillStyle = '#4A9EFF';
            tc.beginPath();
            tc.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
            tc.fill();
          }
          tc.globalAlpha = 1;
          requestAnimationFrame(drawTrail);
        })();
      }

      // ── Update theme-color on theme change ────────────────────────
      const themeColorMeta = document.getElementById('theme-color') as HTMLMetaElement | null;
      new MutationObserver(() => {
        const dark = document.documentElement.dataset.theme !== 'light';
        if (themeColorMeta) themeColorMeta.content = dark ? '#0C1525' : '#D6E4F7';
      }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    </script>
  </body>
</html>
