---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Miguel Padín Domínguez — Software Engineer',
  description = 'Software engineer with 9+ years of experience. Focused on Vue 3, TypeScript and modern web architecture.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <!-- Dot grid spotlight -->
    <div id="grid-spotlight" style="
      position: fixed; inset: 0; pointer-events: none; z-index: 2;
      background-image: radial-gradient(circle, rgba(232,145,74,0.13) 1px, transparent 1px);
      background-size: 38px 38px;
      -webkit-mask-image: radial-gradient(circle 220px at var(--mx, -500px) var(--my, -500px), black 0%, transparent 100%);
      mask-image: radial-gradient(circle 220px at var(--mx, -500px) var(--my, -500px), black 0%, transparent 100%);
    "></div>

    <!-- Scroll progress bar -->
    <div id="scroll-bar" style="
      position: fixed; top: 0; left: 0; z-index: 100000;
      height: 2px; width: 0%;
      background: var(--color-accent);
      pointer-events: none;
    "></div>

    <slot />

    <script>
      const isTouch = window.matchMedia('(pointer: coarse)').matches;

      // ── Split text reveal ─────────────────────────────────────────
      document.querySelectorAll<HTMLElement>('[data-split]').forEach(el => {
        const text = el.textContent || '';
        el.innerHTML = [...text].map((char, i) =>
          `<span class="split-char" style="transition-delay:${(i * 0.045).toFixed(3)}s">${char === ' ' ? '&nbsp;' : char}</span>`
        ).join('');
      });

      const splitObs = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('is-split-visible');
            splitObs.unobserve(e.target);
          }
        });
      }, { threshold: 0.5 });
      document.querySelectorAll('[data-split]').forEach(el => splitObs.observe(el));

      // ── Scroll velocity skew ──────────────────────────────────────
      let scrollVel = 0, currentSkew = 0, lastScrollY = window.scrollY;
      const mainEl = document.querySelector('main') as HTMLElement | null;

      window.addEventListener('scroll', () => {
        scrollVel = window.scrollY - lastScrollY;
        lastScrollY = window.scrollY;
      }, { passive: true });

      if (mainEl && !isTouch) {
        (function skewTick() {
          const target = Math.max(-2.5, Math.min(2.5, scrollVel * 0.055));
          currentSkew += (target - currentSkew) * 0.1;
          scrollVel *= 0.8;
          mainEl!.style.transform = Math.abs(currentSkew) > 0.005
            ? `skewY(${currentSkew.toFixed(4)}deg)`
            : '';
          requestAnimationFrame(skewTick);
        })();
      }

      // ── Dot grid spotlight ────────────────────────────────────────
      const grid = document.getElementById('grid-spotlight')!;
      window.addEventListener('mousemove', (e) => {
        grid.style.setProperty('--mx', e.clientX + 'px');
        grid.style.setProperty('--my', e.clientY + 'px');
      }, { passive: true });

      // ── Scroll reveal ──────────────────────────────────────────────
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));

      // ── Scroll progress bar ────────────────────────────────────────
      const scrollBar = document.getElementById('scroll-bar')!;
      window.addEventListener('scroll', () => {
        const pct = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
        scrollBar.style.width = (pct * 100) + '%';
      }, { passive: true });

      // ── Active nav on scroll ───────────────────────────────────────
      const sectionIds = ['experience', 'skills', 'contact'];
      const navLinks = Object.fromEntries(
        sectionIds.map(id => [id, document.querySelector<HTMLElement>(`a[href="#${id}"]`)])
      );

      const resetNav = () => sectionIds.forEach(id => {
        if (navLinks[id]) navLinks[id]!.style.color = 'var(--color-muted)';
      });

      const sectionObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const link = navLinks[entry.target.id];
          if (!link) return;
          link.style.color = entry.isIntersecting ? 'var(--color-accent)' : 'var(--color-muted)';
        });
      }, { threshold: 0.25 });

      sectionIds.forEach(id => {
        const el = document.getElementById(id);
        if (el) sectionObserver.observe(el);
      });

      // ── Tab title visibility easter egg ───────────────────────────
      const staticTitle = document.title;
      document.addEventListener('visibilitychange', () => {
        document.title = document.hidden ? '👋 ¡Hasta pronto!' : staticTitle;
      });

      // ── Animated favicon ──────────────────────────────────────────
      const fLink = document.querySelector<HTMLLinkElement>('link[rel="icon"]');
      if (fLink) {
        const fc = document.createElement('canvas');
        fc.width = 32; fc.height = 32;
        const fx = fc.getContext('2d')!;
        let fPhase = 0;

        setInterval(() => {
          fPhase += 0.07;
          fx.clearRect(0, 0, 32, 32);

          fx.fillStyle = '#0B0B0D';
          fx.beginPath();
          fx.roundRect(0, 0, 32, 32, 6);
          fx.fill();

          const pulse = 0.25 + Math.sin(fPhase) * 0.2;
          fx.strokeStyle = `rgba(232,145,74,${pulse})`;
          fx.lineWidth = 1;
          fx.beginPath();
          fx.arc(16, 16, 14, 0, Math.PI * 2);
          fx.stroke();

          fx.save();
          fx.translate(16, 16);
          fx.rotate(fPhase * 0.6);
          fx.strokeStyle = 'rgba(232,145,74,0.9)';
          fx.lineWidth = 2.5;
          fx.lineCap = 'round';
          fx.beginPath();
          fx.arc(0, 0, 11, -0.3, Math.PI * 0.65);
          fx.stroke();
          fx.restore();

          fx.fillStyle = '#EDE9E3';
          fx.font = 'bold 10px sans-serif';
          fx.textAlign = 'center';
          fx.textBaseline = 'middle';
          fx.fillText('MP', 16, 16.5);

          fLink.href = fc.toDataURL();
        }, 50);
      }

      // ── Cursor particle trail ─────────────────────────────────────
      if (!isTouch) {
        const trail = document.createElement('canvas');
        trail.style.cssText = 'position:fixed;inset:0;pointer-events:none;z-index:999990;';
        document.body.appendChild(trail);
        const tc = trail.getContext('2d')!;

        function resizeTrail() {
          trail.width  = window.innerWidth;
          trail.height = window.innerHeight;
        }
        resizeTrail();
        window.addEventListener('resize', resizeTrail, { passive: true });

        type Particle = { x: number; y: number; life: number; size: number };
        const particles: Particle[] = [];

        document.addEventListener('mousemove', (e) => {
          if (Math.random() > 0.4) return;
          particles.push({ x: e.clientX, y: e.clientY, life: 1, size: Math.random() * 2.5 + 1 });
        });

        (function drawTrail() {
          tc.clearRect(0, 0, trail.width, trail.height);
          for (let i = particles.length - 1; i >= 0; i--) {
            const p = particles[i];
            p.life -= 0.045;
            if (p.life <= 0) { particles.splice(i, 1); continue; }
            tc.globalAlpha = p.life * 0.55;
            tc.fillStyle = '#E8914A';
            tc.beginPath();
            tc.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
            tc.fill();
          }
          tc.globalAlpha = 1;
          requestAnimationFrame(drawTrail);
        })();
      }
    </script>
  </body>
</html>
