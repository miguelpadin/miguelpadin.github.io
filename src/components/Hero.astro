---
import type { Translations } from '../i18n';

interface Props {
  t: Translations;
}
const { t } = Astro.props;
---

<section id="hero-section" class="relative min-h-screen flex flex-col justify-center px-8 pt-16">

  <!-- Aurora blobs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="hero-blob blob-1"></div>
    <div class="hero-blob blob-2"></div>
    <div class="hero-blob blob-3"></div>
  </div>

  <!-- Particle network canvas -->
  <canvas id="hero-canvas" style="position:absolute;inset:0;pointer-events:none;z-index:0;opacity:0.55;"></canvas>

  <div class="max-w-5xl mx-auto w-full animate-hero relative">

    <div class="flex items-center gap-3 mb-8">
      <span class="pulse-dot"></span>
      <p
        class="text-xs uppercase tracking-[0.25em]"
        style="color: var(--color-accent); font-family: var(--font-display);"
      >
        {t.hero.label}
      </p>
    </div>

    <h1
      id="hero-name"
      class="leading-none mb-10"
      style="
        font-family: var(--font-display);
        font-weight: 800;
        font-size: clamp(3.5rem, 10vw, 7.5rem);
        color: var(--color-fg);
        letter-spacing: -0.02em;
      "
    >
      <span id="para-0" class="scramble-line block" data-text="Miguel">Miguel</span>
      <span id="para-1" class="scramble-line block" data-text="Padín" style="color: var(--color-secondary);">Padín</span>
      <span id="para-2" class="scramble-line block" data-text="Domínguez">Domínguez</span>
    </h1>

    <div
      class="mb-10"
      style="width: 3rem; height: 2px; background: var(--color-accent);"
    ></div>

    <p
      class="max-w-lg text-base leading-loose mb-12"
      style="color: var(--color-secondary); font-weight: 300;"
    >
      {t.hero.bio}
    </p>

    <div class="flex items-center gap-8 flex-wrap">
      {[
        { label: 'LinkedIn',  href: 'https://linkedin.com/in/miguelpadin',       icon: 'linkedin'  },
        { label: 'GitHub',    href: 'https://github.com/miguelpadin',           icon: 'github'    },
        { label: 'Email',     href: 'mailto:miguel.padin.dominguez@gmail.com',  icon: 'mail'      },
        { label: 'WhatsApp',  href: 'https://wa.me/34639476354',                icon: 'whatsapp'  },
        { label: 'Telegram',  href: 'https://t.me/+34639476354',               icon: 'telegram'  },
      ].map(({ label, href, icon }) => (
        <a
          href={href}
          target={href.startsWith('http') ? '_blank' : undefined}
          rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
          class="magnetic flex items-center gap-2.5 transition-colors duration-200"
          style="color: var(--color-muted); font-family: var(--font-display); font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.7rem;"
          onmouseover="this.style.color='var(--color-accent)'"
          onmouseout="this.style.color='var(--color-muted)'"
        >
          {icon === 'linkedin' && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          )}
          {icon === 'github' && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          )}
          {icon === 'mail' && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          )}
          {icon === 'telegram' && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
            </svg>
          )}
          {icon === 'whatsapp' && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
          )}
          {label}
        </a>
      ))}
    </div>
  </div>

</section>

<script>
  // ── Text scramble ──────────────────────────────────────────────
  const CHARS = '!<>-_\\/[]{}—=+*^?#@$%ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';

  function scramble(el: HTMLElement, delay: number) {
    const target = el.dataset.text!;
    let frame = 0;
    const totalFrames = target.length * 6;

    setTimeout(() => {
      const tick = () => {
        let output = '';
        for (let i = 0; i < target.length; i++) {
          const threshold = (i / target.length) * totalFrames;
          if (frame >= threshold + 4) {
            output += target[i];
          } else if (frame >= threshold) {
            output += `<span style="color:var(--color-muted)">${CHARS[Math.floor(Math.random() * CHARS.length)]}</span>`;
          } else {
            output += `<span style="opacity:0">${target[i]}</span>`;
          }
        }
        el.innerHTML = output;
        frame++;
        if (frame <= totalFrames + 4) requestAnimationFrame(tick);
        else el.textContent = target;
      };
      requestAnimationFrame(tick);
    }, delay);
  }

  document.querySelectorAll<HTMLElement>('.scramble-line').forEach((el, i) => {
    scramble(el, 300 + i * 180);
  });


  const isTouch = window.matchMedia('(pointer: coarse)').matches;
  if (!isTouch) {
    // ── Magnetic links ─────────────────────────────────────────
    document.querySelectorAll<HTMLElement>('.magnetic').forEach(el => {
      el.addEventListener('mousemove', (e) => {
        const rect = el.getBoundingClientRect();
        const dx = e.clientX - (rect.left + rect.width  / 2);
        const dy = e.clientY - (rect.top  + rect.height / 2);
        el.classList.add('is-dragging');
        el.style.transform = `translate(${dx * 0.28}px, ${dy * 0.38}px)`;
      });
      el.addEventListener('mouseleave', () => {
        el.classList.remove('is-dragging');
        el.style.transform = 'translate(0, 0)';
      });
    });
  }

  // ── Particle network ───────────────────────────────────────────
  const cvs = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
  const sec = document.getElementById('hero-section') as HTMLElement | null;
  if (cvs && sec) {
    const cx = cvs.getContext('2d')!;

    function resizeCanvas() {
      cvs!.width  = sec!.offsetWidth;
      cvs!.height = sec!.offsetHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas, { passive: true });

    type Pt = { x: number; y: number; vx: number; vy: number };
    const pts: Pt[] = Array.from({ length: 55 }, () => ({
      x:  Math.random() * cvs!.width,
      y:  Math.random() * cvs!.height,
      vx: (Math.random() - 0.5) * 0.35,
      vy: (Math.random() - 0.5) * 0.35,
    }));

    (function drawParticles() {
      cx.clearRect(0, 0, cvs!.width, cvs!.height);
      const base = document.documentElement.dataset.theme === 'light' ? '180,100,30' : '232,145,74';

      pts.forEach(p => {
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0 || p.x > cvs!.width)  p.vx *= -1;
        if (p.y < 0 || p.y > cvs!.height) p.vy *= -1;
      });

      for (let i = 0; i < pts.length; i++) {
        for (let j = i + 1; j < pts.length; j++) {
          const dx = pts[i].x - pts[j].x;
          const dy = pts[i].y - pts[j].y;
          const d  = Math.sqrt(dx * dx + dy * dy);
          if (d < 130) {
            cx.strokeStyle = `rgba(${base},${0.18 * (1 - d / 130)})`;
            cx.lineWidth = 0.6;
            cx.beginPath();
            cx.moveTo(pts[i].x, pts[i].y);
            cx.lineTo(pts[j].x, pts[j].y);
            cx.stroke();
          }
        }
        cx.fillStyle = `rgba(${base},0.45)`;
        cx.beginPath();
        cx.arc(pts[i].x, pts[i].y, 1.5, 0, Math.PI * 2);
        cx.fill();
      }
      requestAnimationFrame(drawParticles);
    })();
  }
</script>
