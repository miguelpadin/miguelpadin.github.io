---
import type { Translations } from '../i18n';

interface Props {
  t: Translations;
}
const { t } = Astro.props;
---

<section id="hero-section" class="relative min-h-screen flex flex-col justify-center px-8 pt-16 overflow-hidden">

  <!-- Aurora blobs -->
  <div class="hero-blob blob-1"></div>
  <div class="hero-blob blob-2"></div>
  <div class="hero-blob blob-3"></div>

  <div class="max-w-5xl mx-auto w-full animate-hero">

    <p
      class="text-xs uppercase tracking-[0.25em] mb-8"
      style="color: var(--color-accent); font-family: var(--font-display);"
    >
      {t.hero.label}
    </p>

    <h1
      id="hero-name"
      class="leading-none mb-10"
      style="
        font-family: var(--font-display);
        font-weight: 800;
        font-size: clamp(3.5rem, 10vw, 7.5rem);
        color: var(--color-fg);
        letter-spacing: -0.02em;
      "
    >
      <span id="para-0" class="scramble-line block" data-text="Miguel">Miguel</span>
      <span id="para-1" class="scramble-line block" data-text="Padín" style="color: var(--color-secondary);">Padín</span>
      <span id="para-2" class="scramble-line block" data-text="Domínguez">Domínguez</span>
    </h1>

    <div
      class="mb-10"
      style="width: 3rem; height: 2px; background: var(--color-accent);"
    ></div>

    <p
      class="max-w-lg text-base leading-loose mb-12"
      style="color: var(--color-secondary); font-weight: 300;"
    >
      {t.hero.bio}
    </p>

    <div class="flex items-center gap-8 flex-wrap">
      {[
        { label: 'LinkedIn', href: 'https://linkedin.com/in/miguelpadin', icon: 'linkedin' },
        { label: 'GitHub',   href: 'https://github.com/miguelpadin',       icon: 'github'   },
        { label: 'Email',    href: 'mailto:miguel.padin.dominguez@gmail.com', icon: 'mail'  },
      ].map(({ label, href, icon }) => (
        <a
          href={href}
          target={href.startsWith('http') ? '_blank' : undefined}
          rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
          class="magnetic flex items-center gap-2.5 transition-colors duration-200"
          style="color: var(--color-muted); font-family: var(--font-display); font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.7rem;"
          onmouseover="this.style.color='var(--color-accent)'"
          onmouseout="this.style.color='var(--color-muted)'"
        >
          {icon === 'linkedin' && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          )}
          {icon === 'github' && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          )}
          {icon === 'mail' && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          )}
          {label}
        </a>
      ))}
    </div>
  </div>

  <div
    class="absolute bottom-10 left-1/2 -translate-x-1/2"
    style="opacity: 0; animation: fadeIn 1s ease 1.2s forwards;"
  >
    <div style="width: 1px; height: 3rem; background: linear-gradient(to bottom, transparent, var(--color-muted));"></div>
  </div>

</section>

<script>
  // ── Text scramble ──────────────────────────────────────────────
  const CHARS = '!<>-_\\/[]{}—=+*^?#@$%ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';

  function scramble(el: HTMLElement, delay: number) {
    const target = el.dataset.text!;
    let frame = 0;
    const totalFrames = target.length * 6;

    setTimeout(() => {
      const tick = () => {
        let output = '';
        for (let i = 0; i < target.length; i++) {
          const threshold = (i / target.length) * totalFrames;
          if (frame >= threshold + 4) {
            output += target[i];
          } else if (frame >= threshold) {
            output += `<span style="color:var(--color-muted)">${CHARS[Math.floor(Math.random() * CHARS.length)]}</span>`;
          } else {
            output += `<span style="opacity:0">${target[i]}</span>`;
          }
        }
        el.innerHTML = output;
        frame++;
        if (frame <= totalFrames + 4) requestAnimationFrame(tick);
        else el.textContent = target;
      };
      requestAnimationFrame(tick);
    }, delay);
  }

  document.querySelectorAll<HTMLElement>('.scramble-line').forEach((el, i) => {
    scramble(el, 300 + i * 180);
  });

  // Activate glitch after entrance animation completes
  setTimeout(() => {
    const heroName = document.getElementById('hero-name');
    if (heroName) {
      heroName.style.opacity = '1';
      heroName.classList.add('hero-name');
    }
  }, 2000);

  // ── Mouse parallax on name ─────────────────────────────────────
  const heroSection = document.getElementById('hero-section')!;
  const paraLayers = [
    { el: document.getElementById('para-0'), depth: 0.010 },
    { el: document.getElementById('para-1'), depth: 0.018 },
    { el: document.getElementById('para-2'), depth: 0.007 },
  ];

  const isTouch = window.matchMedia('(pointer: coarse)').matches;
  if (!isTouch) {
    heroSection.addEventListener('mousemove', (e) => {
      const rect = heroSection.getBoundingClientRect();
      const dx = e.clientX - rect.left - rect.width / 2;
      const dy = e.clientY - rect.top  - rect.height / 2;
      paraLayers.forEach(({ el, depth }) => {
        if (el) el.style.transform = `translate(${dx * depth}px, ${dy * depth}px)`;
      });
    });

    heroSection.addEventListener('mouseleave', () => {
      paraLayers.forEach(({ el }) => {
        if (el) {
          el.style.transition = 'transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
          el.style.transform = 'translate(0, 0)';
          setTimeout(() => { if (el) el.style.transition = ''; }, 800);
        }
      });
    });

    // ── Magnetic links ─────────────────────────────────────────
    document.querySelectorAll<HTMLElement>('.magnetic').forEach(el => {
      el.addEventListener('mousemove', (e) => {
        const rect = el.getBoundingClientRect();
        const dx = e.clientX - (rect.left + rect.width  / 2);
        const dy = e.clientY - (rect.top  + rect.height / 2);
        el.classList.add('is-dragging');
        el.style.transform = `translate(${dx * 0.28}px, ${dy * 0.38}px)`;
      });
      el.addEventListener('mouseleave', () => {
        el.classList.remove('is-dragging');
        el.style.transform = 'translate(0, 0)';
      });
    });
  }
</script>
