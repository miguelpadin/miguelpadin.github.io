---
import type { Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;

const cookiesUrl = lang !== 'en'
  ? `${import.meta.env.BASE_URL}${lang}/cookies/`
  : `${import.meta.env.BASE_URL}cookies/`;

const copy = {
  en: {
    label: 'Cookies',
    necessary: 'Necessary',
    necessaryBadge: 'Always active',
    necessaryDesc: 'Stores your cookie preference.',
    analytics: 'Analytics',
    analyticsBadge: 'Optional',
    analyticsDesc: 'Google Analytics — anonymous usage data.',
    cookies: 'Cookie policy',
    accept: 'Accept all',
    decline: 'Necessary only',
  },
  es: {
    label: 'Cookies',
    necessary: 'Necesarias',
    necessaryBadge: 'Siempre activas',
    necessaryDesc: 'Guarda tu preferencia de cookies.',
    analytics: 'Analíticas',
    analyticsBadge: 'Opcionales',
    analyticsDesc: 'Google Analytics — datos de uso anónimos.',
    cookies: 'Política de cookies',
    accept: 'Aceptar todo',
    decline: 'Solo necesarias',
  },
  gl: {
    label: 'Cookies',
    necessary: 'Necesarias',
    necessaryBadge: 'Sempre activas',
    necessaryDesc: 'Garda a túa preferencia de cookies.',
    analytics: 'Analíticas',
    analyticsBadge: 'Opcionais',
    analyticsDesc: 'Google Analytics — datos de uso anónimos.',
    cookies: 'Política de cookies',
    accept: 'Aceptar todo',
    decline: 'Só necesarias',
  },
} as const;

const c = copy[lang];
---

<div
  id="cookie-banner"
  role="dialog"
  aria-label={c.label}
  aria-live="polite"
  style="
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    transform: translateY(calc(100% + 2rem));
    z-index: 99999;
    width: min(calc(100vw - 3rem), 380px);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    opacity: 0;
    pointer-events: none;
    transition: transform 0.5s cubic-bezier(0.16,1,0.3,1), opacity 0.5s cubic-bezier(0.16,1,0.3,1);
  "
>
  <!-- Label -->
  <p style="
    font-family: var(--font-display);
    font-size: 0.625rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  ">{c.label}</p>

  <!-- Necessary row -->
  <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem;">
    <div>
      <p style="
        font-family: var(--font-display);
        font-size: 0.6875rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-fg);
        margin: 0 0 0.25rem;
      ">{c.necessary}</p>
      <p style="
        font-family: var(--font-body);
        font-size: 0.75rem;
        color: var(--color-muted);
        margin: 0;
        line-height: 1.5;
      ">{c.necessaryDesc}</p>
    </div>
    <span style="
      flex-shrink: 0;
      font-family: var(--font-display);
      font-size: 0.5625rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(74,200,120,0.85);
      background: rgba(74,200,120,0.1);
      border: 1px solid rgba(74,200,120,0.2);
      border-radius: 20px;
      padding: 0.2rem 0.55rem;
      white-space: nowrap;
      margin-top: 0.1rem;
    ">{c.necessaryBadge}</span>
  </div>

  <!-- Divider -->
  <div style="height: 1px; background: var(--color-border);"></div>

  <!-- Analytics row -->
  <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem;">
    <div>
      <p style="
        font-family: var(--font-display);
        font-size: 0.6875rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-fg);
        margin: 0 0 0.25rem;
      ">{c.analytics}</p>
      <p style="
        font-family: var(--font-body);
        font-size: 0.75rem;
        color: var(--color-muted);
        margin: 0;
        line-height: 1.5;
      ">{c.analyticsDesc}</p>
    </div>
    <span style="
      flex-shrink: 0;
      font-family: var(--font-display);
      font-size: 0.5625rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-muted);
      background: transparent;
      border: 1px solid var(--color-border);
      border-radius: 20px;
      padding: 0.2rem 0.55rem;
      white-space: nowrap;
      margin-top: 0.1rem;
    ">{c.analyticsBadge}</span>
  </div>

  <!-- Actions -->
  <div style="display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.125rem;">
    <a
      href={cookiesUrl}
      style="
        font-family: var(--font-display);
        font-size: 0.5625rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--color-muted);
        text-decoration: underline;
        text-underline-offset: 3px;
        transition: color 0.2s;
      "
      onmouseover="this.style.color='var(--color-accent)'"
      onmouseout="this.style.color='var(--color-muted)'"
    >{c.cookies}</a>
    <div style="display: flex; gap: 0.5rem;">
      <button
        id="cookie-decline"
        style="
          font-family: var(--font-display);
          font-size: 0.5625rem;
          letter-spacing: 0.12em;
          text-transform: uppercase;
          color: var(--color-muted);
          background: transparent;
          border: 1px solid var(--color-border);
          border-radius: 4px;
          padding: 0.45rem 0.875rem;
          cursor: pointer;
          transition: color 0.2s, border-color 0.2s;
        "
        onmouseover="this.style.color='var(--color-fg)';this.style.borderColor='var(--color-muted)'"
        onmouseout="this.style.color='var(--color-muted)';this.style.borderColor='var(--color-border)'"
      >{c.decline}</button>
      <button
        id="cookie-accept"
        style="
          font-family: var(--font-display);
          font-size: 0.5625rem;
          letter-spacing: 0.12em;
          text-transform: uppercase;
          color: #111115;
          background: var(--color-accent);
          border: 1px solid transparent;
          border-radius: 4px;
          padding: 0.45rem 0.875rem;
          cursor: pointer;
          transition: opacity 0.2s;
        "
        onmouseover="this.style.opacity='0.82'"
        onmouseout="this.style.opacity='1'"
      >{c.accept}</button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var banner = document.getElementById('cookie-banner');
    if (!banner) return;

    var stored = localStorage.getItem('cookie-consent');

    function applyConsent(value) {
      if (typeof gtag === 'function') {
        gtag('consent', 'update', {
          analytics_storage: value === 'granted' ? 'granted' : 'denied',
        });
      }
    }

    function hideBanner() {
      banner.style.transform = 'translateY(calc(100% + 2rem))';
      banner.style.opacity = '0';
      banner.style.pointerEvents = 'none';
    }

    function showBanner() {
      banner.style.transform = 'translateY(0)';
      banner.style.opacity = '1';
      banner.style.pointerEvents = 'auto';
    }

    if (stored === 'granted') {
      applyConsent('granted');
      return;
    }
    if (stored === 'denied') {
      return;
    }

    setTimeout(showBanner, 900);

    document.getElementById('cookie-accept').addEventListener('click', function () {
      localStorage.setItem('cookie-consent', 'granted');
      applyConsent('granted');
      hideBanner();
    });

    document.getElementById('cookie-decline').addEventListener('click', function () {
      localStorage.setItem('cookie-consent', 'denied');
      hideBanner();
    });
  })();
</script>
