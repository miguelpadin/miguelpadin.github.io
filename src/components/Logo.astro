---
interface Props {
  size?: number;
}
const { size = 32 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 40 40"
  xmlns="http://www.w3.org/2000/svg"
  fill="none"
  aria-label="Miguel Padín Domínguez"
>
  <rect width="40" height="40" rx="7" fill="#0B0B0D"/>
  <rect x="0.5" y="0.5" width="39" height="39" rx="6.5" stroke="#888888" stroke-width="1" fill="none" opacity="0.4"/>
  <text
    x="50%" y="50%"
    text-anchor="middle"
    dominant-baseline="central"
    font-family="Syne, system-ui, sans-serif"
    font-weight="800"
    font-size="15"
    letter-spacing="-1"
    fill="#EDE9E3"
  >MP</text>
</svg>
