---

<section id="skills" class="px-8 py-32" style="background: var(--color-surface);">
  <div class="max-w-5xl mx-auto">

    <div class="flex items-center gap-6 mb-20" data-reveal>
      <span
        class="text-xs uppercase tracking-[0.25em]"
        style="color: var(--color-accent); font-family: var(--font-display); font-weight: 700;"
        data-split
      >
        {t.skills.label}
      </span>
      <div class="divider-line"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-12 lg:gap-16">
      {t.skills.groups.map((group, i) => (
        <div data-reveal data-reveal-delay={String(i % 3)}>
          <p
            class="text-xs uppercase tracking-[0.2em] mb-6"
            style="color: var(--color-muted); font-family: var(--font-display); font-weight: 700;"
          >
            {group.label}
          </p>
          <div class="flex flex-wrap gap-2">
            {group.items.map((item) => {
              const url  = skillUrls[item];
              const icon = icons[item];
              const Tag  = url ? 'a' : 'span';
              const extraProps = url
                ? { href: url, target: '_blank', rel: 'noopener noreferrer' }
                : {};
              return (
                <Tag
                  {...extraProps}
                  class="icon-pill"
                  data-name={item}
                  onmouseover="this.classList.add('hovered')"
                  onmouseout="this.classList.remove('hovered')"
                >
                  {icon?.type === 'si' && (
                    <img
                      src={`https://cdn.simpleicons.org/${icon.slug}`}
                      alt={item}
                      width="18"
                      height="18"
                      class="skill-logo"
                      loading="lazy"
                      onerror="this.style.display='none'"
                    />
                  )}
                  {icon?.type === 'svg' && (
                    <svg
                      viewBox="0 0 24 24"
                      width="18"
                      height="18"
                      fill={icon.stroke ? 'none' : 'currentColor'}
                      stroke={icon.stroke ? 'currentColor' : undefined}
                      stroke-width={icon.stroke ? '2' : undefined}
                      stroke-linecap={icon.stroke ? 'round' : undefined}
                      stroke-linejoin={icon.stroke ? 'round' : undefined}
                      class="skill-logo"
                    >
                      <path d={icon.d} />
                    </svg>
                  )}
                  {!icon && (
                    <span class="icon-fallback">{item.slice(0, 2).toUpperCase()}</span>
                  )}
                </Tag>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <div
      class="mt-20 pt-12 flex flex-wrap gap-10"
      style="border-top: 1px solid var(--color-border);"
      data-reveal
    >
      {[
        { label: t.skills.spanish.label, level: t.skills.spanish.level },
        { label: t.skills.galician.label, level: t.skills.galician.level },
        { label: t.skills.english.label, level: t.skills.english.level },
      ].map(({ label, level }) => (
        <div>
          <p class="text-xs uppercase tracking-[0.2em] mb-2" style="color: var(--color-muted); font-family: var(--font-display);">{label}</p>
          <p class="text-sm" style="color: var(--color-secondary); font-weight: 300;">{level}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .icon-pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    transition: border-color 0.2s, background 0.2s;
    cursor: default;
    text-decoration: none;
  }
  a.icon-pill { cursor: pointer; }

  .icon-pill:hover {
    border-color: var(--color-accent);
    background: rgba(232, 145, 74, 0.05);
  }

  /* Tooltip */
  .icon-pill::after {
    content: attr(data-name);
    position: absolute;
    bottom: calc(100% + 7px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: var(--color-fg);
    color: var(--color-bg);
    font-size: 10px;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 4px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s, transform 0.15s;
    z-index: 100;
  }
  .icon-pill:hover::after {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Monochrome — dark mode */
  html:not([data-theme="light"]) .skill-logo {
    filter: brightness(0) invert(1);
    opacity: 0.75;
  }
  html:not([data-theme="light"]) .icon-pill:hover .skill-logo {
    opacity: 1;
  }

  /* Monochrome — light mode */
  [data-theme="light"] .skill-logo {
    filter: brightness(0);
    opacity: 0.6;
  }
  [data-theme="light"] .icon-pill:hover .skill-logo {
    opacity: 0.9;
  }

  /* Fallback text for skills without icon */
  .icon-fallback {
    font-size: 9px;
    font-family: var(--font-display);
    font-weight: 800;
    color: var(--color-muted);
    letter-spacing: 0.05em;
  }
</style>
